# Build artifacts
spike/spike
spike/inspect.sh
spike/inspect2.sh
# Anything in tests/ or examples/ that isn't a .nim source is a build
# artifact. The negation pattern keeps the .nim files tracked while
# ignoring every compiled binary, shared library, or cache directory
# `nim c -r` deposits next to them.
tests/*
!tests/*.nim
tests/*.so
tests/*.dylib
tests/*.dll
examples/*
!examples/*.nim
examples/*.so
examples/*.dylib
examples/*.dll

# Standalone-module compile artifacts that land next to source.
# I sometimes run `nim c src/z3/foo.nim` to type-check a module in
# isolation; the resulting binary lands at `src/z3/foo` (no extension).
src/z3/*
!src/z3/*.nim
nimcache/
*.o
*.exe

# milpa-managed dep symlinks + nim.cfg (regenerated on `milpa fetch`).
# milpa.kdl and milpa.lock ARE committed.
_deps/
nim.cfg
